# AO1 Intern — Environment Variables
# Copy this file to .env and fill in your values.
# https://hermes-agent.nousresearch.com/docs/user-guide/secrets

# ── Model Provider ─────────────────────────────────────────────
# Required. Get from https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Override the default model (optional).
# Examples: anthropic/claude-sonnet-4, openai/gpt-4o, deepseek/deepseek-chat
AGENT_MODEL=anthropic/claude-sonnet-4
AGENT_PROVIDER=openrouter
AGENT_BASE_URL=https://openrouter.ai/api/v1

# ── AO1 Knowledge Base ─────────────────────────────────────────
# Path to the AO1 KB on this machine.
AO1_KB_PATH=~/Documents/Projects/ao1-kb

# ── Messaging: Telegram ────────────────────────────────────────
# Optional. Get a bot token from https://t.me/BotFather
TELEGRAM_BOT_TOKEN=

# Optional: restrict Telegram DMs to specific user IDs (comma-separated).
# Leave empty to allow all Telegram users.
TELEGRAM_ALLOWED_USER_IDS=

# ── Messaging: Discord ─────────────────────────────────────────
# Optional. Create a bot at https://discord.com/developers/applications
DISCORD_BOT_TOKEN=

# ── Customer Email Processing ──────────────────────────────────
# Optional. Local state directory for customer-email-sorter runtime files.
CUSTOMER_EMAIL_STATE_DIR=

# Optional. Mailbox account name used by the configured mailbox CLI (for example Himalaya).
CUSTOMER_EMAIL_ACCOUNT=

# Optional. Folder to scan for inbound customer/support messages.
CUSTOMER_EMAIL_FOLDER=INBOX

# ── Stripe ─────────────────────────────────────────────────────
# Optional. Required for Stripe billing operations and customer purchase verification.
# Use a restricted/read-only key where possible for support verification jobs.
STRIPE_SECRET_KEY=

# ── Gateway Security ───────────────────────────────────────────
# Shared secret for gateway HTTP endpoints. Generate with: openssl rand -hex 32
HERMES_SECRET=

# ── Optional Providers ─────────────────────────────────────────
# Only needed if using non-default providers.
# ANTHROPIC_API_KEY=
# DEEPSEEK_API_KEY=
# GITHUB_TOKEN=           # For gh CLI integration