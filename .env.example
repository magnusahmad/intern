# AO1 Intern — Environment Variables
# Copy this file to .env and fill in your values during onboarding.
# Secrets are entered LOCALLY at the Terminal and never echoed back. Never paste a secret
# over Telegram. https://hermes-agent.nousresearch.com/docs/user-guide/secrets
#
# Grouped by onboarding phase (see specs/03-onboarding-flow.md). Most values are filled in
# for you by the onboarding skill as you go — you rarely edit this by hand.

# ── Model Provider (Phase 0) ───────────────────────────────────
# Pick whatever model/provider you want. Hermes prompts for the key on first run if it's
# missing. Default is OpenRouter — get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Override the default model/provider (optional). Examples:
#   AGENT_MODEL=anthropic/claude-sonnet-4   AGENT_PROVIDER=openrouter
#   AGENT_MODEL=gpt-4o                       AGENT_PROVIDER=openai
# AGENT_MODEL=anthropic/claude-sonnet-4
# AGENT_PROVIDER=openrouter
# AGENT_BASE_URL=https://openrouter.ai/api/v1

# ── AO1 Knowledge Base (Phase 1) ───────────────────────────────
# Path to the AO1 KB on this machine — the company brain. Onboarding state and all curated
# pages live here.
AO1_KB_PATH=~/Documents/Projects/ao1-kb

# ── Stripe (Phase 4) ───────────────────────────────────────────
# Entered locally during onboarding. Use a restricted/read-only key for setup where possible
# (onboarding is read-only on Stripe).
STRIPE_SECRET_KEY=

# ── Cloudflare (Phase 5) ───────────────────────────────────────
# Optional. `wrangler login` (browser) is the default. Set this only if you prefer
# non-interactive auth. Onboarding never deploys — it authenticates and records only.
CLOUDFLARE_API_TOKEN=

# ── Telegram: the operating channel (Phase 7) ──────────────────
# Bot token from https://t.me/BotFather, entered locally during onboarding.
TELEGRAM_BOT_TOKEN=

# REQUIRED once Telegram is on: lock the bot to your own Telegram user ID (from @userinfobot).
# An unlocked business-ops bot is a security hole. Comma-separated for multiple IDs.
TELEGRAM_ALLOWED_USER_IDS=

# ── Gateway Security ───────────────────────────────────────────
# Shared secret for gateway HTTP endpoints. Generate with: openssl rand -hex 32
HERMES_SECRET=

# ── Optional / not wired by v1 onboarding ──────────────────────
# Customer-email triage stays in the distribution but is NOT set up by onboarding (spec v1).
# CUSTOMER_EMAIL_STATE_DIR=
# CUSTOMER_EMAIL_ACCOUNT=
# CUSTOMER_EMAIL_FOLDER=INBOX
# DISCORD_BOT_TOKEN=
# GITHUB_TOKEN=           # gh uses its own auth (gh auth login) over HTTPS
